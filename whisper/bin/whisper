#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$SCRIPT_DIR/../venv"

input="$1"
output="${input%.*}.mp3"
output_dir=$(dirname "$output")

ffmpeg -loglevel quiet -i "$input" -codec:a libmp3lame -q:a 2 "$output"

PYTHONWARNINGS=ignore "$VENV/bin/whisper" "$output" --model large --output_format txt --output_dir "$output_dir"
