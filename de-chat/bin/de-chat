#!/usr/bin/env python3
"""Convert Claude Code terminal output to vanilla GFM markdown."""
import sys
import re

CHAR_MAP = {
    '—': '--',  # em dash
    '–': '-',   # en dash (used in ranges: 1–2 days → 1-2 days)
    '“': '"',   # left double quotation mark
    '”': '"',   # right double quotation mark
    '‘': "'",   # left single quotation mark
    '’': "'",   # right single quotation mark
}

# ⏺ or ● response marker at start of line
MARKER_RE = re.compile(r'^[⏺●]\s+')
# ▎ blockquote indicator (optional leading spaces, then ▎, then space)
BQ_RE = re.compile(r'^\s*▎\s')
LIST_RE = re.compile(r'^[-*+] |^\d+\. ')
HEADING_RE = re.compile(r'^#{1,6} ')
FENCED_RE = re.compile(r'^(`{3,}|~{3,})')
INDENT_CODE_RE = re.compile(r'^    ')


def transliterate(s):
    for k, v in CHAR_MAP.items():
        s = s.replace(k, v)
    return s


def unwrap_paragraphs(lines):
    result = []
    para = []
    in_fenced = False

    def flush():
        if para:
            result.append(' '.join(para))
            para.clear()

    for line in lines:
        if FENCED_RE.match(line):
            flush()
            in_fenced = not in_fenced
            result.append(line)
            continue
        if in_fenced:
            result.append(line)
            continue
        if not line:
            flush()
            result.append('')
            continue
        if (HEADING_RE.match(line) or line.startswith('>')
                or LIST_RE.match(line) or INDENT_CODE_RE.match(line)):
            flush()
            result.append(line)
            continue
        para.append(line)

    flush()
    return result


def strip_body_indent(line):
    """Strip 1-3 leading spaces but not 4+ (code block indent)."""
    m = re.match(r'^( {1,3})(?! )', line)
    if m:
        return line[len(m.group(1)):]
    return line


def process(text):
    lines = text.splitlines()
    out = []
    i = 0

    while i < len(lines):
        line = lines[i]

        m = MARKER_RE.match(line)
        if m:
            rest = line[len(m.group(0)):]
            bq_m = BQ_RE.match(rest)
            if bq_m:
                preceded_by_blank = not out or out[-1] == ''
                parts = [rest[len(bq_m.group(0)):].strip()]
                i += 1
                while i < len(lines) and BQ_RE.match(lines[i]):
                    bm = BQ_RE.match(lines[i])
                    parts.append(lines[i][len(bm.group(0)):].strip())
                    i += 1
                if preceded_by_blank:
                    out.append('> ' + ' '.join(parts))
                else:
                    out.extend(parts)
            else:
                out.append(rest)
                i += 1
            continue

        if not line.strip():
            out.append('')
            i += 1
            continue

        if BQ_RE.match(line):
            preceded_by_blank = not out or out[-1] == ''
            parts = []
            while i < len(lines) and BQ_RE.match(lines[i]):
                bm = BQ_RE.match(lines[i])
                parts.append(lines[i][len(bm.group(0)):].strip())
                i += 1
            if preceded_by_blank:
                out.append('> ' + ' '.join(parts))
            else:
                out.extend(parts)
            continue

        out.append(strip_body_indent(line))
        i += 1

    # Ensure blank line before the start of a list (not between items)
    result = []
    for line in out:
        if (LIST_RE.match(line) and result
                and result[-1] != ''
                and not LIST_RE.match(result[-1])):
            result.append('')
        result.append(line)

    return transliterate('\n'.join(unwrap_paragraphs(result)))


def main():
    text = sys.stdin.read()
    output = process(text)
    sys.stdout.write(output)
    if output and not output.endswith('\n'):
        sys.stdout.write('\n')


if __name__ == '__main__':
    main()
